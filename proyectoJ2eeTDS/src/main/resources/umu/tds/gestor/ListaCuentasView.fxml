<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="600.0" prefWidth="800.0" spacing="20.0" xmlns="http://javafx.com/javafx/21.0.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.tds.gestor.vista.ListaCuentasViewController">
   <children>
      <VBox prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
         <children>
            <TableView fx:id="tablaCuentas" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="380.0" prefWidth="387.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn prefWidth="75.0" text="Cuentas existentes">
                     <columns>
                        <TableColumn fx:id="colID" text="Id" />
                        <TableColumn fx:id="colParticipantes" prefWidth="216.0" text="Participantes" />
                        <TableColumn fx:id="colGasto" prefWidth="136.0" text="Gasto" />
                     </columns>
                  </TableColumn>
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="20.0" VBox.vgrow="NEVER">
               <children>
                  <Label text="Nombres a filtrar:" />
                  <TextField fx:id="nombresFiltro" />
                  <Button mnemonicParsing="false" onAction="#botonFiltrar" text="Filtrar" />
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="40.0" VBox.vgrow="NEVER">
               <children>
                  <Button mnemonicParsing="false" onAction="#cambiarDistribuciones" text="Cambiar distribuciones" />
                  <Button mnemonicParsing="false" onAction="#borrarCuenta" text="Borrar cuenta" />
               </children>
            </HBox>
         </children>
      </VBox>
      <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
         <children>
            <TableView maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="380.0" prefWidth="353.0" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn prefWidth="302.0" text="Distribuciones">
                     <columns>
                        <TableColumn fx:id="propParticipante" prefWidth="133.0" text="Participante" />
                        <TableColumn fx:id="propPorcentaje" prefWidth="133.0" text="Proporción (%)" />
                        <TableColumn fx:id="propSaldo" prefWidth="133.0" text="Saldo actual" />
                     </columns>
                  </TableColumn>
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="350.0" VBox.vgrow="NEVER">
               <children>
                  <Label prefHeight="54.0" prefWidth="198.0" text="Inserte los nombres de los participantes de la cuenta" textAlignment="CENTER" wrapText="true" VBox.vgrow="ALWAYS">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <TextField fx:id="participantes" maxWidth="180.0" prefHeight="20.0" prefWidth="10.0" promptText="Ej: Mario, Antonio, Pedro" VBox.vgrow="ALWAYS">
                     <VBox.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </VBox.margin>
                  </TextField>
                  <Button mnemonicParsing="false" onAction="#crearCuenta" text="Crear cuenta" VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
         </children>
         <HBox.margin>
            <Insets />
         </HBox.margin>
      </VBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</HBox>
