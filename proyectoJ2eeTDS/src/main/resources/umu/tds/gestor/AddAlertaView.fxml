<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox fx:controller="umu.tds.gestor.vista.AddAlertaViewController" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="500.0" prefWidth="800.0" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" spacing="10.0">
         <children>
            <ComboBox fx:id="comboFiltro" maxWidth="1.7976931348623157E308" promptText="Seleccione filtro (Todas/Semanales/Mensuales)..." />
            <TableView fx:id="tablaAlertas" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn text="Alertas existentes">
                   <columns>
                      <TableColumn fx:id="colNombre" prefWidth="90.0" text="Nombre" />
                      <TableColumn fx:id="colCategoria" prefWidth="130.0" text="Categoría" />
                      <TableColumn fx:id="colLimite" prefWidth="80.0" text="Límite" />
                   </columns>
                </TableColumn>
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
      <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
         <children>
            <Label prefHeight="60.0" prefWidth="180.0" text="Configure una nueva alerta" textAlignment="CENTER" wrapText="true" VBox.vgrow="ALWAYS">
               <font>
                  <Font size="16.0" />
               </font>
            </Label>
            <ComboBox fx:id="comboTipo" maxWidth="180.0" prefWidth="100.0" promptText="Tipo (Mensual/Semanal)" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
               </VBox.margin>
            </ComboBox>
            <ComboBox fx:id="comboCategoria" maxWidth="180.0" prefWidth="100.0" promptText="Categoría (Opcional)" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="0.0" />
               </VBox.margin>
            </ComboBox>
            <TextField fx:id="campoLimite" maxWidth="180.0" prefHeight="20.0" prefWidth="10.0" promptText="Límite en €" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="0.0" />
               </VBox.margin>
            </TextField>
            <Button onAction="#crearAlerta" mnemonicParsing="false" text="Crear alerta" VBox.vgrow="ALWAYS" />
         </children>
         <HBox.margin>
            <Insets top="70.0" />
         </HBox.margin>
      </VBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</HBox>