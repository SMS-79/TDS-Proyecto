<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="500.0" prefWidth="800.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.tds.gestor.vista.AddAlertaViewController">
   <children>
      <VBox prefHeight="200.0" prefWidth="200.0" spacing="10.0" HBox.hgrow="ALWAYS">
         <children>
            <ComboBox fx:id="comboFiltro" maxWidth="1.7976931348623157E308" />
            <TableView fx:id="tablaAlertas" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn text="Alertas">
                   <columns>
                      <TableColumn fx:id="colNombre" prefWidth="90.0" text="Tipo" />
                      <TableColumn fx:id="colCategoria" prefWidth="129.0" text="Categoría" />
                      <TableColumn fx:id="colGastoRealizado" prefWidth="119.0" text="Gasto realizado" />
                      <TableColumn fx:id="colLimite" prefWidth="74.0" text="Límite" />
                   </columns>
                </TableColumn>
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
      <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
         <children>
            <Label prefHeight="60.0" prefWidth="180.0" text="Configure una nueva alerta" textAlignment="CENTER" wrapText="true" VBox.vgrow="ALWAYS">
               <font>
                  <Font size="16.0" />
               </font>
            </Label>
            <ComboBox fx:id="comboTipo" maxWidth="180.0" prefWidth="100.0" promptText="Tipo (Mensual/Semanal)" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
               </VBox.margin>
            </ComboBox>
            <ComboBox fx:id="comboCategoria" maxWidth="180.0" prefWidth="100.0" promptText="Categoría (Opcional)" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="0.0" />
               </VBox.margin>
            </ComboBox>
            <TextField fx:id="campoLimite" maxWidth="180.0" prefHeight="20.0" prefWidth="10.0" promptText="Límite en €" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="0.0" />
               </VBox.margin>
            </TextField>
            <HBox alignment="CENTER" spacing="25.0">
               <children>
                  <Button lineSpacing="15.0" mnemonicParsing="false" onAction="#crearAlerta" prefHeight="27.0" prefWidth="83.0" text="Crear alerta" />
                 	<Button fx:id="botonBorrar" lineSpacing="20.0" mnemonicParsing="false" onAction="#botonBorrar" prefHeight="27.0" prefWidth="89.0" text="Borrar alerta">
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                  </Button>
               </children>
            </HBox>
         </children>
         <HBox.margin>
            <Insets top="70.0" />
         </HBox.margin>
      </VBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</HBox>
