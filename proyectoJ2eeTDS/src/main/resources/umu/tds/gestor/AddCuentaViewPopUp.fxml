<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="501.0" xmlns="http://javafx.com/javafx/21.0.10" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.tds.gestor.vista.AddCuentaViewPopUpController">
   <children>
      <Label prefHeight="122.0" prefWidth="322.0" text="La primera persona introducida será el pagador. Deje los campos de porcentaje en blanco para una distribucion equitativa" wrapText="true">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <VBox prefHeight="200.0" prefWidth="100.0">
         <children>
            <HBox alignment="CENTER" prefHeight="206.0" prefWidth="502.0">
               <children>
                  <VBox alignment="CENTER" prefHeight="143.0" prefWidth="206.0" spacing="20.0">
                     <children>
                        <HBox alignment="CENTER" prefHeight="32.0" prefWidth="194.0" spacing="10.0">
                           <children>
                              <Label text="Gasto:" />
