                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefHeight="143.0" prefWidth="319.0">
                     <children>
                        <HBox alignment="CENTER" prefHeight="48.0" prefWidth="206.0" spacing="10.0">
                           <children>
                              <Label text="Nombre:" />
                              <TextField fx:id="nombreMiembro" prefHeight="26.0" prefWidth="67.0" promptText="Ej: Pedro" />
                              <Label text="\%:" />
                              <TextField fx:id="porcentajeMiembro" prefHeight="26.0" prefWidth="67.0" promptText="Ej: 37.5" />
                           </children>
                        </HBox>
                        <HBox alignment="CENTER" prefHeight="46.0" prefWidth="307.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#addMiembro" text="Añadir miembro" />
