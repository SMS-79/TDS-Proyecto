<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>

<GridPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="250.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.tds.gestor.vista.EditGastoViewPopUpController">
    <columnConstraints>
        <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
        <ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
        <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
    </columnConstraints>
    <rowConstraints>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
    </rowConstraints>
    <children>
        <Label text="Categoría">
            <font>
                <Font size="12.0" />
            </font>
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
         <GridPane.margin>
            <Insets right="15.0" />
         </GridPane.margin>
        </Label>
        <Label text="Fecha del gasto" GridPane.columnIndex="0" GridPane.rowIndex="1">
            <font>
                <Font size="12.0" />
            </font>
         <GridPane.margin>
            <Insets right="15.0" />
         </GridPane.margin>
        </Label>
        <Label text="Cantidad" GridPane.columnIndex="0" GridPane.rowIndex="2">
            <font>
                <Font size="12.0" />
            </font>
         <GridPane.margin>
            <Insets right="15.0" />
         </GridPane.margin>
        </Label>
      	<ChoiceBox fx:id="boxCategorias" prefWidth="150.0" GridPane.columnIndex="1">
         <opaqueInsets>
            <Insets />
         </opaqueInsets></ChoiceBox>
        <DatePicker fx:id="fecha" maxWidth="130.0" promptText="Fecha del gasto" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <TextField fx:id="cantidad" maxWidth="130.0" promptText="Ej: 100.50" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Button mnemonicParsing="false" onAction="#editarGasto" prefHeight="30.0" prefWidth="100.0" text="Editar gasto" GridPane.columnIndex="2" GridPane.halignment="CENTER" GridPane.rowIndex="3" />
    </children>
</GridPane>
