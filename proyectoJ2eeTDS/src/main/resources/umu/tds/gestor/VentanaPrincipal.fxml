<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="500.0" prefWidth="800.0" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.tds.gestor.vista.VentanaPrincipalControlador">
		<padding>
			<Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
		</padding>
  			<children>
	            <TableView fx:id="tablaGastos" prefHeight="400.0" prefWidth="760.0" VBox.vgrow="ALWAYS">
	              <columns>
	                  <TableColumn prefWidth="75.0" text="Lista de Gastos">
	                     <columns>
	                        <TableColumn fx:id="colID" prefWidth="120.0" text="Id" />
	                      	<TableColumn fx:id="colCategoria" prefWidth="200.0" text="Categoría" />
	                      	<TableColumn fx:id="colCantidad" prefWidth="150.0" text="Cantidad" />
	                        <TableColumn fx:id="colFecha" prefWidth="150.0" text="Fecha" />
	                     </columns>
	                  </TableColumn>
	              </columns>
	                  <columnResizePolicy>
	                  	<TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
	                  </columnResizePolicy>
	  
	            </TableView>
     
      <VBox alignment="CENTER" spacing="10.0">
         <children>
            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <TextField fx:id="categoriaFilter" promptText="Categoria" />
                  
                  <DatePicker fx:id="dpFechaInicio" minHeight="10.0" minWidth="100.0" prefHeight="22.0" prefWidth="160.0" promptText="Fecha de inicio" />
                  
                  <DatePicker fx:id="dpFechaFin" minHeight="10.0" minWidth="100.0" prefHeight="22.0" prefWidth="160.0" promptText="Fecha de fin" />
               </children>
            </HBox>
            
            <Button mnemonicParsing="false" onAction="#botonBuscar" prefHeight="20.0" prefWidth="70.0" text="Filtrar" />
         </children>
      </VBox>
   </children>
</VBox>
