<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane fx:controller="umu.tds.gestor.vista.BarraMenuViewController" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
	<top>
		<MenuBar BorderPane.alignment="CENTER">
			<menus>
				<Menu mnemonicParsing="false" text="Tienda">
					<items>
						<MenuItem mnemonicParsing="false" onAction="#irAGastos" text="Lista de Gastos" />
						<MenuItem mnemonicParsing="false" onAction="#irAddGasto" text="Añadir Gasto" />
						<MenuItem mnemonicParsing="false" onAction="#irACategorias" text="Añadir Categoria" />
						<MenuItem mnemonicParsing="false" onAction="#irImportarGastos" text="Importar Gastos" />
						<MenuItem mnemonicParsing="false" onAction="#irAddAlerta" text="Añadir Alerta" /> 
						<MenuItem mnemonicParsing="false" onAction="#salir" text="Salir" />
					</items>
				</Menu>
				<Menu mnemonicParsing="false" text="Ayuda">
					<items>
						<MenuItem mnemonicParsing="false" onAction="#abrirAcerca" text="Acerca de miTienda" />
					</items>
				</Menu>
			</menus>
		</MenuBar>
	</top>
</BorderPane>
